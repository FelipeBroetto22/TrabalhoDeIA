NEURAL ---\")\n","    print(classification_report(y_teste, prev_rna, target_names=['Inteiro', 'Danificado']))\n","\n"]},{"cell_type":"code","execution_count":5,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"elapsed":1306,"status":"ok","timestamp":1782183404982,"user":{"displayName":"Felipe Broetto Araujo","userId":"17931569583089276075"},"user_tz":180},"id":"QA1VJBV0jCMc","outputId":"795872b9-e874-4157-8729-a915ee0e8a27"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Desenhando gráficos de performance...\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x1200 with 6 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["if 'modelo_svm' in locals() and 'modelo_rna' in locals():\n","    print(\"\\nDesenhando gráficos de performance...\")\n","\n","    # Extrair probabilidades para as curvas\n","    prob_svm = modelo_svm.predict_proba(X_teste)[:, 1]\n","    prob_rna = modelo_rna.predict_proba(X_teste)[:, 1]\n","\n","    sns.set_theme(style=\"whitegrid\")\n","    fig, axes = plt.subplots(2, 2, figsize=(16, 12))\n","    fig.suptitle('Análise de Performance Comparativa com Dados Reais', fontsize=18, fontweight='bold')\n","\n","    # 1. Matriz Confusão SVM\n","    sns.heatmap(confusion_matrix(y_teste, prev_svm), annot=True, fmt='d', cmap='Blues', ax=axes[0, 0],\n","                xticklabels=['Previsto Inteiro', 'Previsto Batido'], yticklabels=['Real Inteiro', 'Real Batido'])\n","    axes[0, 0].set_title('1. Matriz de Confusão: SVM', fontsize=14, fontweight='bold')\n","\n","    # 2. Matriz Confusão RNA\n","    sns.heatmap(confusion_matrix(y_teste, prev_rna), annot=True, fmt='d', cmap='Purples', ax=axes[0, 1],\n","                xticklabels=['Previsto Inteiro', 'Previsto Batido'], yticklabels=['Real Inteiro', 'Real Batido'])\n","    axes[0, 1].set_title('2. Matriz de Confusão: Rede Neural (RNA)', fontsize=14, fontweight='bold')\n","\n","    # 3. Curva ROC Comparativa\n","    fpr_svm, tpr_svm, _ = roc_curve(y_teste, prob_svm)\n","    fpr_rna, tpr_rna, _ = roc_curve(y_teste, prob_rna)\n","    axes[1, 0].plot(fpr_svm, tpr_svm, color='blue', lw=2, label=f'SVM (AUC = {auc(fpr_svm, tpr_svm):.2f})')\n","    axes[1, 0].plot(fpr_rna, tpr_rna, color='purple', lw=2, label=f'Rede Neural (AUC = {auc(fpr_rna, tpr_rna):.2f})')\n","    axes[1, 0].plot([0, 1], [0, 1], color='gray', linestyle='--')\n","    axes[1, 0].set_title('3. Curva ROC Comparativa', fontsize=14, fontweight='bold')\n","    axes[1, 0].legend(loc=\"lower right\")\n","\n","    # 4. Precision-Recall Comparativa\n","    prec_svm, rec_svm, _ = precision_recall_curve(y_teste, prob_svm)\n","    prec_rna, rec_rna, _ = precision_recall_curve(y_teste, prob_rna)\n","    axes[1, 1].plot(rec_svm, prec_svm, color='blue', lw=2, label='SVM')\n","    axes[1, 1].plot(rec_rna, prec_rna, color='purple', lw=2, label='Rede Neural')\n","    axes[1, 1].set_title('4. Curva Precision-Recall', fontsize=14, fontweight='bold')\n","    axes[1, 1].legend()\n","\n","    plt.tight_layout()\n","    plt.subplots_adjust(top=0.92)\n","    plt.show()\n"]},{"cell_type":"code","execution_count":6,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":607},"id":"fezHAz1aul8Y","executionInfo":{"status":"ok","timestamp":1782183475876,"user_tz":180,"elapsed":70892,"user":{"displayName":"Felipe Broetto Araujo","userId":"17931569583089276075"}},"outputId":"03f90dfe-d95e-4294-bcc7-4d5aafc7958d"},"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_2151/1140468362.py:46: FutureWarning: \n","\n","Passing `palette` without assigning `hue` is deprecated and will be removed in v0.14.0. Assign the `x` variable to `hue` and set `legend=False` for the same effect.\n","\n","  barras = sns.barplot(x=['SVM (Aula 007)', 'Rede Neural (Aula 009)'],\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x500 with 2 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["caminho_svm_salvo = '/content/drive/MyDrive/databse/modelo_svm.pkl'\n","caminho_rna_salva = '/content/drive/MyDrive/databse/modelo_rna.pkl'\n","\n","if os.path.exists(caminho_svm_salvo) and os.path.exists(caminho_rna_salva):\n","    print(\"\\n--- INICIAR TESTE AO VIVO ---\")\n","    print(\"Aguardando inserção de imagem fotográfica do seu computador...\")\n","\n","    # Carregar modelos treinados da memória\n","    m_svm = joblib.load(caminho_svm_salvo)\n","    m_rna = joblib.load(caminho_rna_salva)\n","\n","    uploaded = files.upload()\n","\n","    for nome in uploaded.keys():\n","        clear_output()\n","\n","        # Leitura da imagem\n","        img_bytes = np.frombuffer(uploaded[nome], np.uint8)\n","        img_original = cv2.imdecode(img_bytes, cv2.IMREAD_COLOR)\n","        img_rgb = cv2.cvtColor(img_original, cv2.COLOR_BGR2RGB)\n","\n","        # Aplicar o MESMO pipeline de otimização/normalização\n","        img_cinza = cv2.cvtColor(img_original, cv2.COLOR_BGR2GRAY)\n","        # Atenção aqui: o / 255.0 é obrigatório pois os modelos foram treinados assim\n","        img_vetor = (cv2.resize(img_cinza, (64, 64)).flatten().reshape(1, -1)) / 255.0\n","\n","        # Predições dos dois modelos\n","        indice_svm = m_svm.predict(img_vetor)[0]\n","        indice_rna = m_rna.predict(img_vetor)[0]\n","\n","        prev_svm = ['Inteiro', 'Danificado'][indice_svm]\n","        prev_rna = ['Inteiro', 'Danificado'][indice_rna]\n","\n","        # Nível de certeza\n","        conf_svm = m_svm.predict_proba(img_vetor)[0][indice_svm] * 100\n","        conf_rna = m_rna.predict_proba(img_vetor)[0][indice_rna] * 100\n","\n","        # Geração do Painel Visual de Resultado\n","        sns.set_theme(style=\"whitegrid\")\n","        fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n","\n","        axes[0].imshow(img_rgb)\n","        axes[0].axis('off')\n","        axes[0].set_title(f\"Diagnóstico SVM: {prev_svm}\\nDiagnóstico RNA: {prev_rna}\", fontsize=13, fontweight='bold')\n","\n","        barras = sns.barplot(x=['SVM (Aula 007)', 'Rede Neural (Aula 009)'],\n","                             y=[conf_svm, conf_rna],\n","                             palette=['#3498db', '#9b59b6'], ax=axes[1])\n","\n","        axes[1].set_ylim(0, 110)\n","        axes[1].set_title(\"Cálculo de Certeza por Modelo (%)\", fontsize=14, fontweight='bold')\n","        axes[1].set_ylabel('Nível de Certeza (%)', fontsize=12)\n","\n","        axes[1].text(0, conf_svm + 3, f\"{prev_svm}\\n{conf_svm:.1f}%\", ha='center', fontweight='bold', color='#2980b9', fontsize=12)\n","        axes[1].text(1, conf_rna + 3, f\"{prev_rna}\\n{conf_rna:.1f}%\", ha='center', fontweight='bold', color='#8e44ad', fontsize=12)\n","\n","        plt.tight_layout()\n","        plt.show()\n","else:\n","    print(\"⚠️ Execute as Pools 1 e 2 primeiro para treinar e gerar os ficheiros dos modelos (.pkl).\")"]}],"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPWpKb/7xHNo/LMjlmNRKce"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}