{"cells":[{"cell_type":"markdown","metadata":{"id":"N4f_g6MTkRoa"},"source":["<div class=\"alert alert-block alert-info\">\n","<b>Disciplina de Inteligência Artificial - Professor Munif - Unicesumar 2026</b><br>\n","Projeto Final: Classificação de Danos em Veículos (K-Means + SVM)<br>\n","Integrantes: Felipe Broetto Araujo e Felipe Duarte Milleo Consulim\n","\n","</div>"]},{"cell_type":"code","execution_count":2,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"executionInfo":{"elapsed":20887,"status":"ok","timestamp":1782183402372,"user":{"displayName":"Felipe Broetto Araujo","userId":"17931569583089276075"},"user_tz":180},"id":"HEFb0NOY1hqB","outputId":"e50aa086-5fbc-4f40-8c0b-77145ebdafe9"},"outputs":[{"output_type":"stream","name":"stdout","text":["Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n","\n","--- INICIANDO EXTRAÇÃO E NORMALIZAÇÃO DE IMAGENS ---\n","\n","✅ Dataset Carregado e Otimizado com Sucesso:\n","-> Treino: 206 imagens prontas para aprendizagem rápida.\n","-> Validação: 191 imagens.\n","-> Teste: 192 imagens para avaliação final.\n"]}],"source":["import os\n","import cv2\n","import joblib\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","from google.colab import drive, files\n","from IPython.display import clear_output\n","from sklearn.svm import SVC\n","from sklearn.neural_network import MLPClassifier\n","from sklearn.metrics import accuracy_score, confusion_matrix, classification_report, roc_curve, auc, precision_recall_curve\n","\n","# Montar o Google Drive\n","drive.mount('/content/drive')\n","\n","pasta_treino = '/content/drive/MyDrive/databse/train'\n","pasta_validacao = '/content/drive/MyDrive/databse/val'\n","pasta_teste = '/content/drive/MyDrive/databse/test'\n","\n","def carregar_dados_por_classes(caminho_geral, tamanho=(64, 64)):\n","    imagens, rotulos = [], []\n","    classes = ['inteiro', 'danificado']\n","\n","    if not os.path.exists(caminho_geral):\n","        print(f\"⚠️ Aviso: Caminho não encontrado -> {caminho_geral}\")\n","        return np.array([]), np.array([])\n","\n","    for indice, classe_nome in enumerate(classes):\n","        caminho_subpasta = os.path.join(caminho_geral, classe_nome)\n","        if not os.path.exists(caminho_subpasta): continue\n","\n","        for nome_arquivo in os.listdir(caminho_subpasta):\n","            if nome_arquivo.lower().endswith(('.jpg', '.jpeg', '.png')):\n","                img = cv2.imread(os.path.join(caminho_subpasta, nome_arquivo))\n","                if img is not None:\n","                    # Engenharia de atributos: Conversão para cinzento e Achatamento (Flatten)\n","                    img_cinza = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n","                    img_redimensionada = cv2.resize(img_cinza, tamanho)\n","\n","                    # OTIMIZAÇÃO CRUCIAL PARA VELOCIDADE DA RNA: Normalização (0 a 1)\n","                    vetor_normalizado = img_redimensionada.flatten() / 255.0\n","\n","                    imagens.append(vetor_normalizado)\n","                    rotulos.append(indice) # 0 = Inteiro, 1 = Danificado\n","\n","    return np.array(imagens), np.array(rotulos)\n","\n","print(\"\\n--- INICIANDO EXTRAÇÃO E NORMALIZAÇÃO DE IMAGENS ---\")\n","X_treino, y_treino = carregar_dados_por_classes(pasta_treino)\n","X_val, y_val = carregar_dados_por_classes(pasta_validacao)\n","X_teste, y_teste = carregar_dados_por_classes(pasta_teste)\n","\n","print(f\"\\n✅ Dataset Carregado e Otimizado com Sucesso:\")\n","print(f\"-> Treino: {len(X_treino)} imagens prontas para aprendizagem rápida.\")\n","print(f\"-> Validação: {len(X_val)} imagens.\")\n","print(f\"-> Teste: {len(X_teste)} imagens para avaliação final.\")\n"]},{"cell_type":"code","execution_count":3,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":1298,"status":"ok","timestamp":1782183403662,"user":{"displayName":"Felipe Broetto Araujo","userId":"17931569583089276075"},"user_tz":180},"id":"Z8cAVV58i7WU","outputId":"9aca5cc3-048b-41d1-f1b6-02ed8c357d62"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","--- INICIANDO TREINO DOS MODELOS ---\n","1/2 - Treinando o Classificador SVM (Aula 007)...\n","2/2 - Treinando a Rede Neural Artificial (Aula 009)...\n","✅ Modelos treinados em tempo recorde!\n","💾 Modelos guardados no Drive em: /content/drive/MyDrive/databse/\n"]}],"source":["if len(X_treino) > 0 and len(np.unique(y_treino)) > 1:\n","    print(\"\\n--- INICIANDO TREINO DOS MODELOS ---\")\n","\n","    print(\"1/2 - Treinando o Classificador SVM (Aula 007)...\")\n","    modelo_svm = SVC(kernel='linear', probability=True, random_state=42)\n","    modelo_svm.fit(X_treino, y_treino)\n","\n","    print(\"2/2 - Treinando a Rede Neural Artificial (Aula 009)...\")\n","    # Otimizado para ser rápido: 50 neurónios, limite de 300 iterações e paragem antecipada (early_stopping)\n","    modelo_rna = MLPClassifier(hidden_layer_sizes=(50,), max_iter=300, early_stopping=True, random_state=42)\n","    modelo_rna.fit(X_treino, y_treino)\n","\n","    print(\"✅ Modelos treinados em tempo recorde!\")\n","\n","    # Exportação física dos modelos (.pkl)\n","    caminho_salvar = '/content/drive/MyDrive/databse/'\n","    joblib.dump(modelo_svm, os.path.join(caminho_salvar, 'modelo_svm.pkl'))\n","    joblib.dump(modelo_rna, os.path.join(caminho_salvar, 'modelo_rna.pkl'))\n","    print(f\"💾 Modelos guardados no Drive em: {caminho_salvar}\")\n","else:\n","    print(\"⚠️ Erro: Poucos dados no treino ou ausência de uma das classes.\")\n"]},{"cell_type":"code","execution_count":4,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":12,"status":"ok","timestamp":1782183403675,"user":{"displayName":"Felipe Broetto Araujo","userId":"17931569583089276075"},"user_tz":180},"id":"VtTRwMQUjAOb","outputId":"87194253-31a4-4b48-be09-e4689547241e"},"outp