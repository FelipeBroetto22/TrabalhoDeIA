{"cells":[{"cell_type":"markdown","metadata":{"id":"N4f_g6MTkRoa"},"source":["<div class=\"alert alert-block alert-info\">\n","<b>Disciplina de Inteligência Artificial - Professor Munif - Unicesumar 2026</b><br>\n","Projeto Final: Classificação de Danos em Veículos (K-Means + SVM)<br>\n","Integrantes: Felipe Broetto Araujo e Felipe Duarte Milleo Consulim\n","\n","</div>"]},{"cell_type":"code","execution_count":61,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"id":"HEFb0NOY1hqB","executionInfo":{"status":"ok","timestamp":1781653144802,"user_tz":180,"elapsed":11140,"user":{"displayName":"Felipe Broetto Araujo","userId":"17931569583089276075"}},"outputId":"f387debd-aa33-40e3-b8dd-95c3fdf57935"},"outputs":[{"output_type":"stream","name":"stdout","text":["Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n","\n","--- INICIANDO EXTRAÇÃO DE IMAGENS ---\n","\n","✅ Dataset Atualizado Carregado com Sucesso:\n","-> Treino: 206 imagens prontas para aprendizagem.\n","-> Validação: 191 imagens.\n","-> Teste: 192 imagens para avaliação final.\n"]}],"source":["# ====================================================================\n","# POOL 1: CONFIGURAÇÃO DE AMBIENTE E CARREGAMENTO DE DADOS\n","# ====================================================================\n","import os\n","import cv2\n","import joblib\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","from google.colab import drive, files\n","from IPython.display import clear_output\n","from sklearn.cluster import KMeans\n","from sklearn.svm import SVC\n","from sklearn.metrics import (accuracy_score, confusion_matrix, classification_report,\n","                             silhouette_score, davies_bouldin_score, roc_curve, auc, precision_recall_curve)\n","from sklearn.decomposition import PCA\n","\n","# 1. Conexão com o Google Drive\n","drive.mount('/content/drive')\n","\n","# 2. Caminhos das pastas (cenário com subpastas 'inteiro' e 'danificado')\n","pasta_treino = '/content/drive/MyDrive/databse/train'\n","pasta_validacao = '/content/drive/MyDrive/databse/val'\n","pasta_teste = '/content/drive/MyDrive/databse/test'\n","\n","def carregar_dados_por_classes(caminho_geral, tamanho=(64, 64)):\n","    imagens = []\n","    rotulos = []\n","    classes = ['inteiro', 'danificado']\n","\n","    if not os.path.exists(caminho_geral):\n","        print(f\"⚠️ Diretório raiz não encontrado: {caminho_geral}\")\n","        return np.array([]), np.array([])\n","\n","    for indice, classe_nome in enumerate(classes):\n","        caminho_subpasta = os.path.join(caminho_geral, classe_nome)\n","        if not os.path.exists(caminho_subpasta):\n","            continue\n","\n","        for nome_arquivo in os.listdir(caminho_subpasta):\n","            if nome_arquivo.lower().endswith(('.jpg', '.jpeg', '.png')):\n","                caminho_arquivo = os.path.join(caminho_subpasta, nome_arquivo)\n","                img = cv2.imread(caminho_arquivo)\n","                if img is not None:\n","                    # Pré-processamento: escala de cinza e redimensionamento\n","                    img_cinza = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n","                    img_redimensionada = cv2.resize(img_cinza, tamanho)\n","                    # Achatamento (Flatten) para o SVM\n","                    imagens.append(img_redimensionada.flatten())\n","                    rotulos.append(indice) # 0 = Inteiro, 1 = Danificado\n","\n","    return np.array(imagens), np.array(rotulos)\n","\n","print(\"\\n--- INICIANDO EXTRAÇÃO DE IMAGENS ---\")\n","X_treino, y_treino = carregar_dados_por_classes(pasta_treino)\n","X_val, y_val = carregar_dados_por_classes(pasta_validacao)\n","X_teste, y_teste = carregar_dados_por_classes(pasta_teste)\n","\n","print(f\"\\n✅ Dataset Atualizado Carregado com Sucesso:\")\n","print(f\"-> Treino: {len(X_treino)} imagens prontas para aprendizagem.\")\n","print(f\"-> Validação: {len(X_val)} imagens.\")\n","print(f\"-> Teste: {len(X_teste)} imagens para avaliação final.\")"]},{"cell_type":"code","execution_count":62,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Z8cAVV58i7WU","executionInfo":{"status":"ok","timestamp":1781653145266,"user_tz":180,"elapsed":461,"user":{"displayName":"Felipe Broetto Araujo","userId":"17931569583089276075"}},"outputId":"abc92f79-642c-479a-c996-488459a5e339"},"outputs":[{"output_type":"stream","name":"stdout","text":["--- TREINANDO O CLASSIFICADOR SVM (PARTE 1) ---\n","✅ SVM calibrado com sucesso!\n","\n","====================================\n"," ACURÁCIA FINAL (TESTE): 82.29%\n","====================================\n","\n","--- Relatório de Métricas Detalhadas ---\n","              precision    recall  f1-score   support\n","\n","     Inteiro       0.91      0.78      0.84       114\n","  Danificado       0.73      0.88      0.80        78\n","\n","    accuracy                           0.82       192\n","   macro avg       0.82      0.83      0.82       192\n","weighted avg       0.84      0.82      0.82       192\n","\n"]}],"source":["# ====================================================================\n","# POOL 2: INDUÇÃO DO MODELO PREDITIVO (SVM)\n","# ====================================================================\n","if len(X_treino) > 0 and len(np.unique(y_treino)) > 1:\n","    print(\"--- TREINANDO O CLASSIFICADOR SVM (PARTE 1) ---\")\n","\n","    # Kernel linear para lidar com os 4096 atributos extraídos das imagens\n","    modelo_svm = SVC(kernel='linear', probability=True, random_state=42)\n","    modelo_svm.fit(X_treino, y_treino)\n","    print(\"✅ SVM calibrado com sucesso!\")\n","\n","    # Avaliação rigorosa na pasta de Teste\n","    previsoes_teste = modelo_svm.predict(X_teste)\n","    acc_teste = accuracy_score(y_teste, previsoes_teste)\n","\n","    print(f\"\\n====================================\")\n","    print(f\" ACURÁCIA FINAL (TESTE): {acc_teste * 100:.2f}%\")\n","    print(f\"====================================\\n\")\n","    print(\"--- Relatório de Métricas Detalhadas ---\")\n","    print(classification_report(y_teste, previsoes_teste, target_names=['Inteiro', 'Danificado']))\n","else:\n","    print(\"⚠️ Erro: Poucos dados no treino ou ausência de uma das classes.\")"]},{"cell_type":"code","execution_count":63,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"VtTRwMQUjAOb","executionInfo":{"status":"ok","timestamp":1781653145942,"user_tz":180,"elapsed":677,"user":{"displayName":"Felipe Broetto Araujo","userId":"17931569583089276075"}},"outputId":"6d0931ed-d287-4af4-8262-eccc80fc1ab4"},"outputs":[{"output_type":"stream","name":"stdout","text":["--- EXECUTANDO O ALGORITMO K-MEANS (PARTE 2) ---\n","✅ Agrupamento finalizado!\n","\n","--- Métricas de Validação dos Clusters (Aula 013) ---\n","Índice Silhouette: 0.277 (Mede a coesão/separação)\n","Índice Davies-Bouldin: 1.435 (Quanto menor, melhor a separabilidade)\n","\n","💾 Modelos físicos salvos em: /content/drive/MyDrive/databse/\n"]}],"source":["# ====================================================================\n","# POOL 3: AGRUPAMENTO DESCRITIVO E EXPORTAÇÃO (K-MEANS)\n","# ====================================================================\n","if len(X_treino) > 0:\n","    print(\"--- EXECUTANDO O ALGORITMO K-MEANS (PARTE 2) ---\")\n","\n","    # Buscando 2 clusters naturais sem olhar para as classes humanas\n","    kmeans = KMeans(n_clusters=2, random_state=42, n_init=10)\n","    clusters_treino = kmeans.fit_predict(X_treino)\n","    clusters_teste = kmeans.predict(X_teste)\n","\n","    print(\"✅ Agrupamento finalizado!\")\n","\n","    # Avaliação Interna (Conforme exigência da Aula 013)\n","    silhueta = silhouette_score(X_treino, clusters_treino)\n","    db = davies_bouldin_score(X_treino, clusters_treino)\n","    print(f\"\\n--- Métricas de Validação dos Clusters (Aula 013) ---\")\n","    print(f\"Índice Silhouette: {silhueta:.3f} (Mede a coesão/separação)\")\n","    print(f\"Índice Davies-Bouldin: {db:.3f} (Quanto menor, melhor a separabilidade)\")\n","\n","    # Salvando os arquivos físicos .pkl para a entrega do projeto\n","    caminho_salvar = '/content/drive/MyDrive/databse/'\n","    joblib.dump(kmeans, os.path.join(caminho_salvar, 'modelo_kmeans.pkl'))\n","    joblib.dump(modelo_svm, os.path.join(caminho_salvar, 'modelo_svm.pkl'))\n","    print(f\"\\n💾 Modelos físicos salvos em: {caminho_salvar}\")"]},{"cell_type":"code","execution_count":64,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"QA1VJBV0jCMc","executionInfo":{"status":"ok","timestamp":1781653148832,"user_tz":180,"elapsed":2868,"user":{"displayName":"Felipe Broetto Araujo","userId":"17931569583089276075"}},"outputId":"ac648041-2951-45f5-cd0d-70092a455442"},"outputs":[{"output_type":"stream","name":"stdout","text":["Desenhando gráficos de performance...\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x1200 with 5 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["# ====================================================================\n","# POOL 4: GERAÇÃO DO PAINEL VISUAL DE AVALIAÇÃO\n","# ====================================================================\n","if 'modelo_svm' in locals() and 'kmeans' in locals():\n","    print(\"Desenhando gráficos de performance...\")\n","    probabilidades = modelo_svm.predict_proba(X_teste)[:, 1]\n","\n","    sns.set_theme(style=\"whitegrid\")\n","    fig, axes = plt.subplots(2, 2, figsize=(16, 12))\n","    fig.suptitle('Análise de Performance do Modelo com Dados Reais', fontsize=18, fontweight='bold')\n","\n","    # 1. Matriz de Confusão\n","    matriz = confusion_matrix(y_teste, previsoes_teste)\n","    sns.heatmap(matriz, annot=True, fmt='d', cmap='Oranges', ax=axes[0, 0],\n","                xticklabels=['Previsto Inteiro', 'Previsto Batido'],\n","                yticklabels=['Real Inteiro', 'Real Batido'], annot_kws={\"size\": 14})\n","    axes[0, 0].set_title('1. Matriz de Confusão (Aula 012)', fontsize=14, fontweight='bold')\n","\n","    # 2. PCA Clusters\n","    pca = PCA(n_components=2)\n","    X_pca = pca.fit_transform(X_teste)\n","    sns.scatterplot(x=X_pca[:, 0], y=X_pca[:, 1], hue=clusters_teste, palette='Set1', s=100, edgecolor='black', ax=axes[0, 1])\n","    axes[0, 1].set_title('2. Dispersão de Clusters via PCA (Aula 013)', fontsize=14, fontweight='bold')\n","\n","    # 3. Curva ROC\n","    fpr, tpr, _ = roc_curve(y_teste, probabilidades)\n","    roc_auc = auc(fpr, tpr)\n","    axes[1, 0].plot(fpr, tpr, color='darkorange', lw=2, label=f'Área AUC = {roc_auc:.2f}')\n","    axes[1, 0].plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--')\n","    axes[1, 0].set_title('3. Curva ROC', fontsize=14, fontweight='bold')\n","    axes[1, 0].legend(loc=\"lower right\")\n","\n","    # 4. Curva Precision-Recall\n","    precision, recall, _ = precision_recall_curve(y_teste, probabilidades)\n","    axes[1, 1].plot(recall, precision, color='purple', lw=2)\n","    axes[1, 1].set_title('4. Curva Precision-Recall', fontsize=14, fontweight='bold')\n","\n","    plt.tight_layout()\n","    plt.subplots_adjust(top=0.92)\n","    plt.show()"]},{"cell_type":"code","execution_count":65,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":394},"id":"fezHAz1aul8Y","executionInfo":{"status":"error","timestamp":1781653157941,"user_tz":180,"elapsed":9107,"user":{"displayName":"Felipe Broetto Araujo","userId":"17931569583089276075"}},"outputId":"a16f18da-4c11-4007-a77d-76a841c0e4d0"},"outputs":[{"output_type":"stream","name":"stdout","text":["Aguardando inserção de imagem fotográfica...\n"]},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["\n","     <input type=\"file\" id=\"files-65f7849a-496b-4836-b1bf-e5c4140e2e74\" name=\"files[]\" multiple disabled\n","        style=\"border:none\" />\n","     <output id=\"result-65f784