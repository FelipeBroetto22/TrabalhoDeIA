do. Execute o Pool 3 antes de iniciar os testes.\")\n","else:\n","    modelo_svm = joblib.load(caminho_modelo)\n","    print(\"Aguardando inserção de imagem fotográfica...\")\n","\n","    uploaded = files.upload()\n","\n","    for nome_arquivo in uploaded.keys():\n","        clear_output()\n","\n","        # Pipeline idêntico ao exigido pela teoria\n","        img_bytes = np.frombuffer(uploaded[nome_arquivo], np.uint8)\n","        img_original = cv2.imdecode(img_bytes, cv2.IMREAD_COLOR)\n","        img_rgb = cv2.cvtColor(img_original, cv2.COLOR_BGR2RGB)\n","\n","        img_cinza = cv2.cvtColor(img_original, cv2.COLOR_BGR2GRAY)\n","        img_redimensionada = cv2.resize(img_cinza, (64, 64))\n","        img_vetor = img_redimensionada.flatten().reshape(1, -1)\n","\n","        # Predição e Extração de Probabilidade\n","        previsao = modelo_svm.predict(img_vetor)[0]\n","        probabilidades = modelo_svm.predict_proba(img_vetor)[0]\n","\n","        classes_nomes = ['Veículo Inteiro', 'Veículo Danificado']\n","        classe_final = classes_nomes[previsao]\n","        cor_layout = \"#2ca02c\" if previsao == 0 else \"#d62728\"\n","\n","        sns.set_theme(style=\"whitegrid\")\n","        fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n","\n","        # Painel Visual - Imagem\n","        axes[0].imshow(img_rgb)\n","        axes[0].axis('off')\n","        axes[0].set_title(f\"Diagnóstico Final:\\n{classe_final}\", fontsize=15, fontweight='bold', color=cor_layout)\n","\n","        # Painel Visual - Gráfico de Confiança\n","        sns.barplot(x=classes_nomes, y=probabilidades * 100, ax=axes[1], palette=['#2ca02c', '#d62728'])\n","        axes[1].set_ylim(0, 105)\n","        axes[1].set_ylabel('Cálculo de Certeza (%)', fontsize=12)\n","        axes[1].set_title('Análise Probabilística do Classificador Linear', fontsize=13, fontweight='bold')\n","\n","        for idx, prob in enumerate(probabilidades):\n","            axes[1].text(idx, prob * 100 + 2, f\"{prob * 100: